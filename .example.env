DISABLE_PRE_COMMIT_FORMAT=false
DISABLE_PRE_COMMIT_LINT=false
DISABLE_PRE_PUSH_TYPECHECK=false
DISABLE_PRE_PUSH_LINT=false

# Enable debug features (true | false)
DEBUG=false

# Mode: dev | preview | prod
MODE="dev"

# Public base URL (required)
APP_URL=http://localhost:3000


## Server routes auth
API_TOKEN="<SEE_PROTON_VAULT>"

# APP_URL in prod environment. Used as base url for images
PROD_URL=

# AI Assistant
AI_GATEWAY_API_KEY="<vercel-ai-gateway-api-key>"

# Cloudflare config
CLOUDFLARE_ACCOUNT_ID="<SEE_PROTON_VAULT>"
CLOUDFLARE_API_TOKEN="<SEE_PROTON_VAULT>"
CLOUDFLARE_CACHE_NAMESPACE_ID="<SEE_PROTON_VAULT>"
CLOUDFLARE_D1_DATABASE_ID="<SEE_PROTON_VAULT>"
CLOUDFLARE_R2_BUCKET="<SEE_PROTON_VAULT>"
WORKER_NAME=local

# Storage Credentials
S3_ACCESS_KEY_ID=<r2_access_key_id>
S3_SECRET_ACCESS_KEY=<r2_secret_access_key>
S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
S3_BUCKET=<r2_bucket_name>   # should be the same as CLOUDFLARE_R2_BUCKET
S3_PUBLIC_URL=https://pub-<hash>.r2.dev

# Optional override (defaults to APP_URL host)
PLAUSIBLE_DOMAIN=

# Disable tracking (true | false)
DISABLE_TRACKING=false


# Studio Github Auth App Credentials
STUDIO_GITHUB_CLIENT_ID=<your_github_client_id>
STUDIO_GITHUB_CLIENT_SECRET=<your_github_client_secret>

# Sentry build/runtime configuration
SENTRY_ENABLED=true
SENTRY_AUTH_TOKEN="<SEE_PROTON_VAULT>"
SENTRY_PROJECT="<YOUR_SENTRY_PROJECT_SLUG>"
SENTRY_ORG="<YOUR_SENTRY_ORG_SLUG>"
SENTRY_DSN="<YOUR_SENTRY_DSN>"
SENTRY_UPLOAD_SOURCE_MAPS=true
